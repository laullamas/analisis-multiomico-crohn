/*
 * nextflow.config — Configuración del pipeline metagenómico (Módulo B)
 *
 * Servidor de cálculo: Dayhoff (Universidad de Murcia)
 * Gestor de colas:     SLURM
 */

// ---------------------------------------------------------------------------
// Perfiles de ejecución
// ---------------------------------------------------------------------------
profiles {

    // ------------------------------------------------------------------
    // Perfil principal: clúster Dayhoff (SLURM) + conda
    // Uso: nextflow run main.nf -profile dayhoff --outdir results/
    // ------------------------------------------------------------------
    dayhoff {

        process.executor = 'slurm'
        process.queue    = 'eck-q'      // partición por defecto (1 día)

        conda.enabled    = true

        // --- Opciones por proceso según recursos necesarios ------------
        process {
            withLabel: 'process_low' {
                queue  = 'eck-q'
                cpus   = 2
                memory = '4.GB'
                time   = '1.h'
            }
            withLabel: 'process_medium' {
                queue  = 'eck-q'
                cpus   = 4
                memory = '16.GB'
                time   = '2.h'
            }
            withLabel: 'process_high' {
                queue  = 'eck-q'
                cpus   = 8
                memory = '28.GB'
                time   = '4.h'
            }
            withLabel: 'process_high_memory' {
                // Kraken2 Standard-Full requiere ~100 GB RAM
                queue  = 'eck-q'
                cpus   = 8
                memory = '110.GB'
                time   = '24.h'
            }
        }

        // --- Límite de jobs simultáneos en cola ------------------------
        executor {
            queueSize = 10
        }
    }

    // ------------------------------------------------------------------
    // Perfil conda standalone (ejecución local o sin SLURM)
    // Uso: nextflow run main.nf -profile conda --outdir results/
    // ------------------------------------------------------------------
    conda {
        conda.enabled    = true
        process.executor = 'local'
    }

    // ------------------------------------------------------------------
    // Perfil de prueba rápida — verifica sintaxis y flujo de canales
    // sin ejecutar ninguna herramienta real (usar con -stub)
    // Uso: nextflow run main.nf -stub -profile test
    // ------------------------------------------------------------------
    test {
        params {
            samplesheet         = "${projectDir}/test/samplesheet_test.csv"
            outdir              = "${projectDir}/test/results"
            bowtie2_index       = "${projectDir}/test"
            bowtie2_index_name  = "dummy"
            kraken2_db          = "${projectDir}/test"
            kraken2_confidence  = 0.1
            bracken_read_length = 100
            bracken_threshold   = 10
        }
        // En stub run los procesos solo hacen 'touch', no necesitan recursos reales
        // Los withLabel sobreescriben los bloques globales del mismo nombre
        process {
            cpus   = 1
            memory = '2.GB'
            time   = '10.min'
            withLabel: 'process_low'         { cpus = 1; memory = '2.GB'; time = '10.min' }
            withLabel: 'process_medium'      { cpus = 1; memory = '2.GB'; time = '10.min' }
            withLabel: 'process_high'        { cpus = 1; memory = '2.GB'; time = '10.min' }
            withLabel: 'process_high_memory' { cpus = 1; memory = '2.GB'; time = '10.min' }
        }
    }
}

// ---------------------------------------------------------------------------
// Parámetros globales del pipeline
// ---------------------------------------------------------------------------
params {

    // --- Input / Output ---
    samplesheet = "${projectDir}/samplesheet.csv"
    outdir      = "${projectDir}/results"

    // --- Bowtie2: índice del genoma humano GRCh38 ---
    // TODO: sustituir por la ruta real en Dayhoff
    // Buscar con: find /datos -name "*.bt2" 2>/dev/null | head -5
    bowtie2_index      = "/TODO/bowtie2_index/GRCh38"
    bowtie2_index_name = "GRCh38"

    // --- Kraken2 / Bracken: base de datos Standard-Full ---
    // TODO: sustituir por la ruta real en Dayhoff
    // Si no existe, construirla con: kraken2-build --standard --threads 16 --db /ruta/db
    kraken2_db         = "/TODO/kraken2_standard_full"
    kraken2_confidence = 0.1

    // --- Bracken ---
    // Longitud de lectura 100 bp: la BD Standard-Full (2024-09-04) fue construida
    // con distribuciones Bracken precomputadas para 100 bp (HiSeq 2000)
    bracken_read_length = 100
    bracken_threshold   = 10
}

// ---------------------------------------------------------------------------
// Recursos por proceso — valores de reserva genéricos
// ---------------------------------------------------------------------------
// IMPORTANTE: los bloques withLabel NO se definen aquí porque este bloque
// se evalúa después de 'profiles {}' y sobreescribiría las anulaciones del
// perfil 'test'. Todos los withLabel están en el perfil 'dayhoff'.
// Con '-profile test' estos valores se sobreescriben a 2.GB (ver arriba).
process {
    cpus   = 4
    memory = '8.GB'
    time   = '2.h'

    // --- Directorios de publicación para los dos alias de FALCO ----------
    // FALCO se importa dos veces (DSL2 alias): hay que publicar en
    // subdirectorios distintos para que los ficheros no se sobreescriban.
    withName: 'FALCO_RAW'     { ext.publish_dir = 'falco/raw'     }
    withName: 'FALCO_TRIMMED' { ext.publish_dir = 'falco/trimmed' }
}

// ---------------------------------------------------------------------------
// Informe de ejecución y trazabilidad
// ---------------------------------------------------------------------------
report {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_report.html"
}

timeline {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_timeline.html"
}

trace {
    enabled = true
    overwrite = true
    file    = "${params.outdir}/pipeline_trace.txt"
}

// ---------------------------------------------------------------------------
// Manifest del pipeline
// ---------------------------------------------------------------------------
manifest {
    name        = 'moduloB-metagenomics'
    description = 'Pipeline metagenómico: fastp → Bowtie2 → Kraken2 → Bracken'
    author      = 'Laura Llamas López · María Sánchez Vivo'
    version     = '1.0.0'
    nextflowVersion = '>=23.04.0'
    mainScript  = 'main.nf'
}
